font-family = JetBrains Mono
font-style = SemiBold
font-size = 15
font-feature = -calt, -liga, -dlig

background-opacity = 0.9
background-blur-radius = 20

theme = Nord

window-padding-x = 0
window-padding-y = 4

confirm-close-surface = false

# Dim inactive splits (approximates WezTerm brightness=0.3)
unfocused-split-opacity = 0.3

# Pane navigation (mirrors WezTerm Ctrl+Shift+h/j/k/l)
keybind = ctrl+shift+h=goto_split:left
keybind = ctrl+shift+j=goto_split:down
keybind = ctrl+shift+k=goto_split:up
keybind = ctrl+shift+l=goto_split:right

# Tab navigation
keybind = shift+escape=next_tab

# Splits
keybind = super+shift+d=new_split:right
keybind = super+d=new_split:down

# Close pane or tab
keybind = super+w=close_surface
